  "description": "Invoice Processor – Gmail to Nordea pain.001",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc && cp -r src/views dist/views && cp -r src/public dist/public && cp src/config/gmail-rules.json dist/config/gmail-rules.json",
