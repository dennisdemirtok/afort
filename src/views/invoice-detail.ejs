<!DOCTYPE html>
<html class="light" lang="sv">
<head>
  <meta charset="utf-8"/>
  <meta content="width=device-width, initial-scale=1.0" name="viewport"/>
  <title>AFORT - Faktura <%= invoice.invoice_number || '' %></title>
  <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700;800&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet"/>
  <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet"/>
  <script src="https://cdn.tailwindcss.com?plugins=forms"></script>
  <style>
    body { font-family: 'Inter', sans-serif; background-color: #f7f9fc; color: #29343a; }
    .font-manrope { font-family: 'Manrope', sans-serif; }
    .material-symbols-outlined { font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24; display: inline-block; }
  </style>
</head>
<body>
  <header class="fixed top-0 w-full z-50 bg-[#f7f9fc] flex justify-between items-center px-8 h-20">
    <div class="flex items-center gap-12">
      <a href="/invoices" class="text-2xl font-bold tracking-tight font-manrope">AFORT</a>
      <nav class="hidden md:flex gap-2 items-center">
        <a class="font-manrope text-sm font-bold text-[#0c56d0] px-3 py-2 rounded-xl" href="/invoices">Fakturor</a>
        <a class="font-manrope text-sm font-medium text-[#29343a]/60 hover:bg-[#e8eff4] px-3 py-2 rounded-xl" href="/payment-files">Betalfiler</a>
        <a class="font-manrope text-sm font-medium text-[#29343a]/60 hover:bg-[#e8eff4] px-3 py-2 rounded-xl" href="/payment-files/create">Skapa betalfil</a>
        <a class="font-manrope text-sm font-medium text-[#29343a]/60 hover:bg-[#e8eff4] px-3 py-2 rounded-xl" href="/api/export/csv">CSV Export</a>
      </nav>
    </div>
    <a href="/logout" class="font-manrope text-sm text-[#29343a]/60 hover:bg-[#e8eff4] px-3 py-2 rounded-xl">Logga ut</a>
  </header>

  <main class="pt-24 pb-16 px-8 max-w-5xl mx-auto">
    <!-- Breadcrumb -->
    <div class="mb-8 flex items-center gap-2 text-sm text-[#566168]">
      <a href="/invoices" class="hover:text-[#0c56d0] transition-colors flex items-center gap-1">
        <span class="material-symbols-outlined text-sm">arrow_back</span> Fakturor
      </a>
      <span>/</span>
      <span class="text-[#29343a] font-medium"><%= invoice.invoice_number || invoice.id.substring(0,8) %></span>
    </div>

    <!-- Header -->
    <div class="flex items-start justify-between mb-8">
      <div class="flex items-center gap-4">
        <% var initials = (invoice.vendor_name || '??').substring(0,2).toUpperCase(); %>
        <div class="w-14 h-14 rounded-xl bg-[#0c56d0]/10 flex items-center justify-center text-[#0c56d0] font-bold text-lg font-manrope"><%= initials %></div>
        <div>
          <h1 class="text-2xl font-extrabold font-manrope tracking-tight"><%= invoice.vendor_name || 'Okand leverantor' %></h1>
          <p class="text-[#566168] text-sm mt-1">Faktura <%= invoice.invoice_number || '-' %></p>
        </div>
      </div>
      <div class="flex items-center gap-3">
        <% if (invoice.pdf_path) { %>
          <a href="/invoices/<%= invoice.id %>/pdf" class="flex items-center gap-2 bg-white ring-1 ring-[#a8b3bb]/20 px-4 py-2.5 rounded-xl hover:bg-[#e8eff4] transition-all text-sm font-medium">
            <span class="material-symbols-outlined text-[#0c56d0]">picture_as_pdf</span> Ladda ner PDF
          </a>
        <% } %>
        <% var sc = invoice.status === 'new' ? 'bg-[#0c56d0] text-white' : invoice.status === 'approved' ? 'bg-emerald-600 text-white' : invoice.status === 'exported' ? 'bg-amber-500 text-white' : 'border-2 border-emerald-600 text-emerald-600'; %>
        <% var sl = invoice.status === 'new' ? 'Ny' : invoice.status === 'approved' ? 'Godkand' : invoice.status === 'exported' ? 'Exporterad' : 'Betald'; %>
        <span class="inline-flex items-center px-4 py-2 rounded-full text-sm font-bold <%= sc %>"><%= sl %></span>
      </div>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
      <!-- Main: Edit form -->
      <div class="lg:col-span-2 bg-white rounded-xl shadow-[0_8px_48px_rgba(41,52,58,0.06)] border border-[#a8b3bb]/10 p-8">
        <h2 class="text-lg font-bold font-manrope mb-6 flex items-center gap-2">
          <span class="material-symbols-outlined text-[#0c56d0]">edit_note</span> Fakturadata
        </h2>
        <form method="POST" action="/invoices/<%= invoice.id %>" class="space-y-5">
          <div class="grid grid-cols-2 gap-4">
            <div>
              <label class="block text-xs font-semibold uppercase tracking-wider text-[#566168] mb-1.5">Leverantor</label>
              <input type="text" name="vendor_name" value="<%= invoice.vendor_name || '' %>" class="w-full bg-white border border-[#a8b3bb]/20 rounded-xl px-4 py-3 text-sm focus:ring-2 focus:ring-[#0c56d0]/20 focus:border-[#0c56d0] outline-none"/>
            </div>
            <div>
              <label class="block text-xs font-semibold uppercase tracking-wider text-[#566168] mb-1.5">Fakturanr</label>
              <input type="text" name="invoice_number" value="<%= invoice.invoice_number || '' %>" class="w-full bg-white border border-[#a8b3bb]/20 rounded-xl px-4 py-3 text-sm focus:ring-2 focus:ring-[#0c56d0]/20 focus:border-[#0c56d0] outline-none font-mono"/>
            </div>
          </div>
          <div class="grid grid-cols-2 gap-4">
            <div>
              <label class="block text-xs font-semibold uppercase tracking-wider text-[#566168] mb-1.5">Belopp</label>
              <input type="number" step="0.01" name="amount" value="<%= invoice.amount || '' %>" class="w-full bg-white border border-[#a8b3bb]/20 rounded-xl px-4 py-3 text-sm focus:ring-2 focus:ring-[#0c56d0]/20 focus:border-[#0c56d0] outline-none"/>
            </div>
            <div>
              <label class="block text-xs font-semibold uppercase tracking-wider text-[#566168] mb-1.5">Valuta</label>
              <select name="currency" class="w-full bg-white border border-[#a8b3bb]/20 rounded-xl px-4 py-3 text-sm focus:ring-2 focus:ring-[#0c56d0]/20 focus:border-[#0c56d0] outline-none">
                <option value="SEK" <%= invoice.currency === 'SEK' ? 'selected' : '' %>>SEK</option>
                <option value="EUR" <%= invoice.currency === 'EUR' ? 'selected' : '' %>>EUR</option>
                <option value="USD" <%= invoice.currency === 'USD' ? 'selected' : '' %>>USD</option>
                <option value="DKK" <%= invoice.currency === 'DKK' ? 'selected' : '' %>>DKK</option>
                <option value="PLN" <%= invoice.currency === 'PLN' ? 'selected' : '' %>>PLN</option>
              </select>
            </div>
          </div>
          <div class="grid grid-cols-2 gap-4">
            <div>
              <label class="block text-xs font-semibold uppercase tracking-wider text-[#566168] mb-1.5">Forfallodatum</label>
              <input type="date" name="due_date" value="<%= invoice.due_date || '' %>" class="w-full bg-white border border-[#a8b3bb]/20 rounded-xl px-4 py-3 text-sm focus:ring-2 focus:ring-[#0c56d0]/20 focus:border-[#0c56d0] outline-none"/>
            </div>
            <div>
              <label class="block text-xs font-semibold uppercase tracking-wider text-[#566168] mb-1.5">Status</label>
              <select name="status" class="w-full bg-white border border-[#a8b3bb]/20 rounded-xl px-4 py-3 text-sm focus:ring-2 focus:ring-[#0c56d0]/20 focus:border-[#0c56d0] outline-none">
                <option value="new" <%= invoice.status === 'new' ? 'selected' : '' %>>Ny</option>
                <option value="approved" <%= invoice.status === 'approved' ? 'selected' : '' %>>Godkand</option>
                <option value="exported" <%= invoice.status === 'exported' ? 'selected' : '' %>>Exporterad</option>
                <option value="paid" <%= invoice.status === 'paid' ? 'selected' : '' %>>Betald</option>
              </select>
            </div>
          </div>
          <div class="grid grid-cols-2 gap-4">
            <div>
              <label class="block text-xs font-semibold uppercase tracking-wider text-[#566168] mb-1.5">OCR</label>
              <input type="text" name="ocr" value="<%= invoice.ocr || '' %>" class="w-full bg-white border border-[#a8b3bb]/20 rounded-xl px-4 py-3 text-sm focus:ring-2 focus:ring-[#0c56d0]/20 focus:border-[#0c56d0] outline-none font-mono"/>
            </div>
            <div>
              <label class="block text-xs font-semibold uppercase tracking-wider text-[#566168] mb-1.5">Bankgiro</label>
              <input type="text" name="bankgiro" value="<%= invoice.bankgiro || '' %>" class="w-full bg-white border border-[#a8b3bb]/20 rounded-xl px-4 py-3 text-sm focus:ring-2 focus:ring-[#0c56d0]/20 focus:border-[#0c56d0] outline-none font-mono"/>
            </div>
          </div>
          <div class="grid grid-cols-2 gap-4">
            <div>
              <label class="block text-xs font-semibold uppercase tracking-wider text-[#566168] mb-1.5">Plusgiro</label>
              <input type="text" name="plusgiro" value="<%= invoice.plusgiro || '' %>" class="w-full bg-white border border-[#a8b3bb]/20 rounded-xl px-4 py-3 text-sm focus:ring-2 focus:ring-[#0c56d0]/20 focus:border-[#0c56d0] outline-none font-mono"/>
            </div>
            <div>
              <label class="block text-xs font-semibold uppercase tracking-wider text-[#566168] mb-1.5">IBAN</label>
              <input type="text" name="iban" value="<%= invoice.iban || '' %>" class="w-full bg-white border border-[#a8b3bb]/20 rounded-xl px-4 py-3 text-sm focus:ring-2 focus:ring-[#0c56d0]/20 focus:border-[#0c56d0] outline-none font-mono"/>
            </div>
          </div>
          <div class="pt-2">
            <button type="submit" class="bg-gradient-to-br from-[#0c56d0] to-[#004aba] text-white font-manrope font-bold py-3 px-8 rounded-xl shadow-lg shadow-[#0c56d0]/20 hover:opacity-95 active:scale-[0.98] transition-all flex items-center gap-2">
              <span class="material-symbols-outlined text-sm">save</span> Spara andringar
            </button>
          </div>
        </form>
      </div>

      <!-- Sidebar: Email info -->
      <div class="space-y-6">
        <div class="bg-white rounded-xl shadow-[0_8px_48px_rgba(41,52,58,0.06)] border border-[#a8b3bb]/10 p-6">
          <h3 class="text-sm font-bold font-manrope uppercase tracking-wider text-[#566168] mb-4 flex items-center gap-2">
            <span class="material-symbols-outlined text-[#0c56d0] text-sm">mail</span> E-postinfo
          </h3>
          <div class="space-y-4 text-sm">
            <div>
              <span class="text-xs text-[#566168] uppercase tracking-wider font-semibold">Fran</span>
              <p class="mt-0.5 text-[#29343a] break-all"><%= invoice.sender || '-' %></p>
            </div>
            <div>
              <span class="text-xs text-[#566168] uppercase tracking-wider font-semibold">Amne</span>
              <p class="mt-0.5 text-[#29343a]"><%= invoice.subject || '-' %></p>
            </div>
            <div>
              <span class="text-xs text-[#566168] uppercase tracking-wider font-semibold">Mottagen</span>
              <p class="mt-0.5 text-[#29343a]"><%= invoice.received_at ? invoice.received_at.substring(0,10) : '-' %></p>
            </div>
            <div>
              <span class="text-xs text-[#566168] uppercase tracking-wider font-semibold">Processad</span>
              <p class="mt-0.5 text-[#29343a]"><%= invoice.processed_at ? invoice.processed_at.substring(0,10) : '-' %></p>
            </div>
          </div>
        </div>

        <div class="bg-white rounded-xl shadow-[0_8px_48px_rgba(41,52,58,0.06)] border border-[#a8b3bb]/10 p-6">
          <h3 class="text-sm font-bold font-manrope uppercase tracking-wider text-[#566168] mb-4 flex items-center gap-2">
            <span class="material-symbols-outlined text-[#0c56d0] text-sm">info</span> Snabbinfo
          </h3>
          <div class="space-y-3 text-sm">
            <div class="flex justify-between">
              <span class="text-[#566168]">Belopp</span>
              <span class="font-bold"><%= invoice.amount ? Number(invoice.amount).toFixed(2) + ' ' + (invoice.currency || '') : '-' %></span>
            </div>
            <div class="flex justify-between">
              <span class="text-[#566168]">Forfaller</span>
              <span class="font-medium"><%= invoice.due_date || '-' %></span>
            </div>
            <div class="flex justify-between">
              <span class="text-[#566168]">OCR</span>
              <span class="font-mono"><%= invoice.ocr || '-' %></span>
            </div>
            <div class="flex justify-between">
              <span class="text-[#566168]">BG</span>
              <span class="font-mono"><%= invoice.bankgiro || '-' %></span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </main>
</body>
</html>
