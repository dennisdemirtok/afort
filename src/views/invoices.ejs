<!DOCTYPE html>
<html class="light" lang="sv">
<head>
  <meta charset="utf-8"/>
  <meta content="width=device-width, initial-scale=1.0" name="viewport"/>
  <title>AFORT - Fakturor</title>
  <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700;800&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet"/>
  <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet"/>
  <script src="https://cdn.tailwindcss.com?plugins=forms"></script>
  <style>
    body { font-family: 'Inter', sans-serif; background-color: #f7f9fc; color: #29343a; }
    .font-manrope { font-family: 'Manrope', sans-serif; }
    .material-symbols-outlined { font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24; display: inline-block; }
  </style>
</head>
<body>
  <header class="fixed top-0 w-full z-50 bg-[#f7f9fc] flex justify-between items-center px-8 h-20">
    <div class="flex items-center gap-12">
      <a href="/invoices" class="text-2xl font-bold tracking-tight font-manrope">AFORT</a>
      <nav class="hidden md:flex gap-2 items-center">
        <a class="font-manrope text-sm font-bold text-[#0c56d0] px-3 py-2 rounded-xl" href="/invoices">Fakturor</a>
        <a class="font-manrope text-sm font-medium text-[#29343a]/60 hover:bg-[#e8eff4] px-3 py-2 rounded-xl" href="/payment-files">Betalfiler</a>
        <a class="font-manrope text-sm font-medium text-[#29343a]/60 hover:bg-[#e8eff4] px-3 py-2 rounded-xl" href="/payment-files/create">Skapa betalfil</a>
        <a class="font-manrope text-sm font-medium text-[#29343a]/60 hover:bg-[#e8eff4] px-3 py-2 rounded-xl" href="/bank-upload">Bankutdrag</a>
        <a class="font-manrope text-sm font-medium text-[#29343a]/60 hover:bg-[#e8eff4] px-3 py-2 rounded-xl" href="/api/export/csv">CSV Export</a>
        <a class="font-manrope text-sm font-medium text-[#29343a]/60 hover:bg-[#e8eff4] px-3 py-2 rounded-xl" href="/settings">Installningar</a>
      </nav>
    </div>
    <a href="/logout" class="font-manrope text-sm text-[#29343a]/60 hover:bg-[#e8eff4] px-3 py-2 rounded-xl">Logga ut</a>
  </header>

  <main class="pt-24 pb-16 px-8 max-w-7xl mx-auto">
    <section class="mb-10">
      <h1 class="text-4xl font-extrabold font-manrope tracking-tight mb-2">Fakturor</h1>
      <p class="text-[#566168] text-sm">Hantera och automatisera ditt kassaflode effektivt.</p>
    </section>

    <div class="flex flex-wrap gap-4 mb-8 items-center justify-between">
      <div class="bg-[#f0f4f8] p-1.5 rounded-xl flex gap-1 items-center flex-wrap">
        <a href="/invoices" class="px-5 py-2.5 rounded-lg text-sm font-semibold <% if (!filters.status) { %>bg-white shadow-sm text-[#0c56d0]<% } else { %>text-[#566168] hover:bg-[#e8eff4]<% } %> transition-all">Alla <span class="ml-1 opacity-50"><%= counts.all %></span></a>
        <a href="/invoices?status=new" class="px-5 py-2.5 rounded-lg text-sm font-medium <% if (filters.status === 'new') { %>bg-white shadow-sm text-[#0c56d0]<% } else { %>text-[#566168] hover:bg-[#e8eff4]<% } %> transition-all">Nya <span class="ml-1 opacity-50"><%= counts.new %></span></a>
        <a href="/invoices?status=approved" class="px-5 py-2.5 rounded-lg text-sm font-medium <% if (filters.status === 'approved') { %>bg-white shadow-sm text-[#0c56d0]<% } else { %>text-[#566168] hover:bg-[#e8eff4]<% } %> transition-all">Godkanda <span class="ml-1 opacity-50"><%= counts.approved %></span></a>
        <a href="/invoices?status=exported" class="px-5 py-2.5 rounded-lg text-sm font-medium <% if (filters.status === 'exported') { %>bg-white shadow-sm text-[#0c56d0]<% } else { %>text-[#566168] hover:bg-[#e8eff4]<% } %> transition-all">Exporterade <span class="ml-1 opacity-50"><%= counts.exported %></span></a>
        <a href="/invoices?status=paid" class="px-5 py-2.5 rounded-lg text-sm font-medium <% if (filters.status === 'paid') { %>bg-white shadow-sm text-[#0c56d0]<% } else { %>text-[#566168] hover:bg-[#e8eff4]<% } %> transition-all">Betalda <span class="ml-1 opacity-50"><%= counts.paid %></span></a>
      </div>
      <form method="GET" action="/invoices" class="flex gap-2">
        <input type="hidden" name="status" value="<%= filters.status || '' %>">
        <div class="relative">
          <span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-[#566168] text-lg">search</span>
          <input class="pl-10 pr-4 py-2.5 bg-white ring-1 ring-[#a8b3bb]/20 rounded-xl focus:ring-2 focus:ring-[#0c56d0] outline-none text-sm w-56" placeholder="Sok leverantor..." name="vendor" value="<%= filters.vendor || '' %>"/>
        </div>
        <button type="submit" class="bg-white p-2.5 rounded-xl ring-1 ring-[#a8b3bb]/20 hover:bg-[#e8eff4]">
          <span class="material-symbols-outlined text-[#566168]">tune</span>
        </button>
      </form>
    </div>

    <div class="bg-white rounded-xl overflow-hidden shadow-[0_32px_48px_-12px_rgba(41,52,58,0.06)]">
      <div class="overflow-x-auto">
        <table class="w-full text-left border-collapse">
          <thead>
            <tr class="bg-[#f0f4f8]">
              <th class="px-6 py-4 text-xs font-bold font-manrope uppercase tracking-wider text-[#566168]">Datum</th>
              <th class="px-6 py-4 text-xs font-bold font-manrope uppercase tracking-wider text-[#566168]">Leverantor</th>
              <th class="px-6 py-4 text-xs font-bold font-manrope uppercase tracking-wider text-[#566168]">Fakturanr</th>
              <th class="px-6 py-4 text-xs font-bold font-manrope uppercase tracking-wider text-[#566168] text-right">Belopp</th>
              <th class="px-6 py-4 text-xs font-bold font-manrope uppercase tracking-wider text-[#566168]">Forfaller</th>
              <th class="px-6 py-4 text-xs font-bold font-manrope uppercase tracking-wider text-[#566168]">Status</th>
              <th class="px-6 py-4 text-xs font-bold font-manrope uppercase tracking-wider text-[#566168] text-center w-20">PDF</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-[#f0f4f8]">
            <% if (invoices.length === 0) { %>
              <tr><td colspan="7" class="px-6 py-12 text-center text-[#566168]">Inga fakturor hittades</td></tr>
            <% } %>
            <% invoices.forEach(function(inv) {
              var initials = (inv.vendor_name || '??').substring(0,2).toUpperCase();
              var sc = inv.status === 'new' ? 'bg-[#0c56d0] text-white' : inv.status === 'approved' ? 'bg-emerald-600 text-white' : inv.status === 'exported' ? 'bg-amber-500 text-white' : 'border-2 border-emerald-600 text-emerald-600';
              var sl = inv.status === 'new' ? 'Ny' : inv.status === 'approved' ? 'Godkand' : inv.status === 'exported' ? 'Exporterad' : 'Betald';
              var amt = inv.amount ? Number(inv.amount).toFixed(2) + ' ' + (inv.currency || '') : '-';
              var ds = inv.received_at ? inv.received_at.substring(0,10) : '-';
            %>
            <tr class="group hover:bg-[#f7f9fc] transition-colors cursor-pointer" onclick="location.href='/invoices/<%= inv.id %>'">
              <td class="px-6 py-5 text-sm"><%= ds %></td>
              <td class="px-6 py-5">
                <div class="flex items-center gap-3">
                  <div class="w-8 h-8 rounded-lg bg-[#0c56d0]/10 flex items-center justify-center text-[#0c56d0] font-bold text-xs"><%= initials %></div>
                  <span class="text-sm font-semibold"><%= inv.vendor_name || '-' %></span>
                </div>
              </td>
              <td class="px-6 py-5 text-sm font-mono text-[#566168]"><%= inv.invoice_number || '-' %></td>
              <td class="px-6 py-5 text-sm font-bold text-right"><%= amt %></td>
              <td class="px-6 py-5 text-sm text-[#566168]"><%= inv.due_date || '-' %></td>
              <td class="px-6 py-5"><span class="inline-flex items-center px-3 py-1 rounded-full text-xs font-bold <%= sc %>"><%= sl %></span></td>
              <td class="px-6 py-5 text-center">
                <% if (inv.pdf_path) { %>
                  <a href="/invoices/<%= inv.id %>/pdf" class="text-[#566168] hover:text-[#0c56d0] transition-colors" onclick="event.stopPropagation()"><span class="material-symbols-outlined">picture_as_pdf</span></a>
                <% } else { %>-<% } %>
              </td>
            </tr>
            <% }); %>
          </tbody>
        </table>
      </div>
      <div class="px-6 py-4 bg-[#f0f4f8] flex justify-between items-center border-t border-[#e8eff4]">
        <span class="text-xs text-[#566168] font-medium">Visar <%= invoices.length %> fakturor</span>
      </div>
    </div>
  </main>
</body>
</html>
