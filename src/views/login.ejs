<!DOCTYPE html>
<html class="light" lang="sv">
<head>
  <meta charset="utf-8"/>
  <meta content="width=device-width, initial-scale=1.0" name="viewport"/>
  <title>AFORT - Logga in</title>
  <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;700;800&family=Inter:wght@400;500;600&display=swap" rel="stylesheet"/>
  <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet"/>
  <script src="https://cdn.tailwindcss.com?plugins=forms"></script>
  <script>
    tailwind.config = { theme: { extend: {
      colors: { primary: "#0c56d0", "primary-dim": "#004aba", "on-primary": "#f8f7ff", "on-surface": "#29343a", "on-surface-variant": "#566168", "surface-container-lowest": "#ffffff", "surface-container": "#e8eff4", "surface-dim": "#cedce5", "outline-variant": "#a8b3bb", background: "#f7f9fc" },
      fontFamily: { headline: ["Manrope"], body: ["Inter"] }
    }}}
  </script>
  <style>
    body { font-family: 'Inter', sans-serif; }
    h1, h2, h3 { font-family: 'Manrope', sans-serif; }
    .material-symbols-outlined { font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24; }
  </style>
</head>
<body class="bg-background text-on-surface min-h-screen flex flex-col">
  <header class="fixed top-0 w-full flex justify-between items-center px-8 h-20 bg-[#f7f9fc]">
    <div class="text-2xl font-bold tracking-tight text-[#29343a] font-headline">AFORT</div>
  </header>
  <main class="flex-grow flex items-center justify-center px-4 pt-20 pb-24">
    <div class="relative w-full max-w-[440px]">
      <div class="absolute -top-12 -right-12 w-32 h-32 bg-primary/5 rounded-full blur-3xl"></div>
      <div class="absolute -bottom-16 -left-16 w-48 h-48 bg-[#546073]/5 rounded-full blur-3xl"></div>
      <div class="bg-surface-container-lowest rounded-xl p-10 shadow-[0_8px_48px_rgba(41,52,58,0.06)] border border-outline-variant/10 relative z-10">
        <div class="mb-10">
          <h1 class="text-3xl font-extrabold tracking-tight text-on-surface mb-2">
            <span class="text-primary">AFORT</span>
          </h1>
          <p class="text-on-surface-variant font-body text-sm tracking-wide">Faktura-automat</p>
        </div>
        <% if (error) { %>
          <div class="mb-4 p-3 rounded-lg bg-red-50 text-red-700 text-sm border border-red-200">Fel losenord. Forsok igen.</div>
        <% } %>
        <form method="POST" action="/login" class="space-y-6">
          <div>
            <label class="block text-xs font-semibold uppercase tracking-wider text-on-surface-variant mb-2 ml-1" for="password">Losenord</label>
            <div class="relative group">
              <input class="w-full bg-surface-container-lowest border border-outline-variant/20 rounded-xl px-4 py-3.5 text-on-surface focus:ring-4 focus:ring-primary/10 focus:border-primary transition-all duration-200 outline-none" id="password" name="password" type="password" required autofocus/>
              <span class="material-symbols-outlined absolute right-4 top-1/2 -translate-y-1/2 text-on-surface-variant/40 group-focus-within:text-primary transition-colors">lock</span>
            </div>
          </div>
          <div class="pt-2">
            <button class="w-full bg-gradient-to-br from-primary to-primary-dim text-on-primary font-headline font-bold py-4 rounded-xl shadow-lg shadow-primary/20 hover:opacity-95 active:scale-[0.98] transition-all duration-200 flex justify-center items-center gap-2" type="submit">
              Logga in
              <span class="material-symbols-outlined text-lg">arrow_forward</span>
            </button>
          </div>
        </form>
      </div>
      <div class="mt-8 px-10">
        <div class="flex items-center gap-4 text-on-surface-variant/40">
          <div class="h-[1px] flex-grow bg-surface-container"></div>
          <span class="material-symbols-outlined text-sm">verified_user</span>
          <div class="h-[1px] flex-grow bg-surface-container"></div>
        </div>
      </div>
    </div>
  </main>
</body>
</html>
