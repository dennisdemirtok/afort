<!DOCTYPE html>
<html class="light" lang="sv">
<head>
  <title>AFORT - Skapa betalfil</title>
  <%- include('partials/head') %>
</head>
<body class="flex min-h-screen">
  <%- include('partials/navbar') %>
  <main class="flex-grow pt-24 pb-12 px-8 ml-64 max-w-5xl mx-auto">
    <div class="mb-8 flex items-center gap-2 text-sm text-[#566168]">
      <a href="/payment-files" class="hover:text-[#0c56d0] transition-colors flex items-center gap-1">
        <span class="material-symbols-outlined text-sm">arrow_back</span> Betalfiler
      </a>
      <span>/</span>
      <span class="text-[#29343a] font-medium">Skapa ny</span>
    </div>

    <h1 class="text-3xl font-extrabold font-manrope tracking-tight mb-8">Skapa betalfil</h1>

    <% if (invoices.length === 0) { %>
      <div class="bg-white rounded-xl p-8 shadow-[0_8px_48px_rgba(41,52,58,0.06)] border border-[#a8b3bb]/10 text-center">
        <span class="material-symbols-outlined text-4xl text-[#a8b3bb] mb-4">info</span>
        <p class="text-[#566168]">Inga godkanda fakturor. Godkann fakturor forst.</p>
      </div>
    <% } else { %>
      <form method="POST" action="/payment-files/create">
        <div class="bg-white rounded-xl p-6 shadow-[0_8px_48px_rgba(41,52,58,0.06)] border border-[#a8b3bb]/10 mb-6">
          <label class="block text-xs font-semibold uppercase tracking-wider text-[#566168] mb-2">Exekveringsdatum</label>
          <input type="date" name="execution_date" value="<%= new Date().toISOString().split('T')[0] %>" required class="bg-white border border-[#a8b3bb]/20 rounded-xl px-4 py-3 text-sm focus:ring-2 focus:ring-[#0c56d0]/20 focus:border-[#0c56d0] outline-none w-48"/>
        </div>

        <div class="bg-white rounded-xl overflow-hidden shadow-[0_32px_48px_-12px_rgba(41,52,58,0.06)]">
          <table class="w-full text-left border-collapse">
            <thead>
              <tr class="bg-[#f0f4f8]">
                <th class="px-6 py-4"><input type="checkbox" id="select-all" class="rounded"/></th>
                <th class="px-6 py-4 text-xs font-bold font-manrope uppercase tracking-wider text-[#566168]">Leverantor</th>
                <th class="px-6 py-4 text-xs font-bold font-manrope uppercase tracking-wider text-[#566168]">Fakturanr</th>
                <th class="px-6 py-4 text-xs font-bold font-manrope uppercase tracking-wider text-[#566168] text-right">Belopp</th>
                <th class="px-6 py-4 text-xs font-bold font-manrope uppercase tracking-wider text-[#566168]">Forfaller</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-[#f0f4f8]">
              <% invoices.forEach(function(inv) { %>
                <tr class="hover:bg-[#f7f9fc] transition-colors">
                  <td class="px-6 py-4"><input type="checkbox" name="invoice_ids" value="<%= inv.id %>" class="rounded"/></td>
                  <td class="px-6 py-4 text-sm font-semibold"><%= inv.vendor_name || '-' %></td>
                  <td class="px-6 py-4 text-sm font-mono text-[#566168]"><%= inv.invoice_number || '-' %></td>
                  <td class="px-6 py-4 text-sm font-bold text-right"><%= inv.amount ? Number(inv.amount).toFixed(2) + ' ' + (inv.currency || '') : '-' %></td>
                  <td class="px-6 py-4 text-sm text-[#566168]"><%= inv.due_date || '-' %></td>
                </tr>
              <% }); %>
            </tbody>
          </table>
          <div class="px-6 py-4 bg-[#f0f4f8] border-t border-[#e8eff4]">
            <button type="submit" class="bg-gradient-to-br from-[#0c56d0] to-[#004aba] text-white font-manrope font-bold py-3 px-8 rounded-xl shadow-lg shadow-[#0c56d0]/20 hover:opacity-95 active:scale-[0.98] transition-all flex items-center gap-2 text-sm">
              <span class="material-symbols-outlined text-sm">payments</span> Skapa pain.001-fil
            </button>
          </div>
        </div>
      </form>
      <script>
        document.getElementById('select-all').addEventListener('change', function() {
          document.querySelectorAll('input[name="invoice_ids"]').forEach(function(cb) { cb.checked = this.checked; }.bind(this));
        });
      </script>
    <% } %>
  </main>
</body>
</html>