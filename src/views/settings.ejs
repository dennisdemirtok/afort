<!DOCTYPE html>
<html class="light" lang="sv">
<head>
  <title>AFORT - Inställningar</title>
  <%- include('partials/head') %>
</head>
<body class="flex min-h-screen">
  <%- include('partials/navbar') %>

  <main class="flex-grow pt-24 pb-12 px-8 ml-64 max-w-[1100px]">
    <section class="mb-10">
      <h1 class="text-4xl font-extrabold font-manrope tracking-tight mb-2">Inställningar</h1>
      <p class="text-[#566168] text-sm">Hantera användare, leverantörer och systeminställningar.</p>
    </section>

    <% if (typeof success !== 'undefined' && success) { %>
      <div class="mb-6 p-4 rounded-xl bg-emerald-50 text-emerald-700 text-sm border border-emerald-200 flex items-center gap-2">
        <span class="material-symbols-outlined text-sm">check_circle</span> <%= success %>
      </div>
    <% } %>

    <div class="space-y-8">
      <!-- Users / Access -->
      <div class="bg-white rounded-xl shadow-[0_8px_48px_rgba(41,52,58,0.06)] border border-[#a8b3bb]/10 p-8">
        <h2 class="text-lg font-bold font-manrope mb-2 flex items-center gap-2">
          <span class="material-symbols-outlined text-[#0c56d0]">group</span> Användare & Åtkomst
        </h2>
        <p class="text-[#566168] text-sm mb-6">Bjud in din bokförare eller andra medarbetare. De loggar in med sin unika länk — inget lösenord att komma ihåg.</p>

        <div class="mb-6">
          <h3 class="text-sm font-semibold text-[#566168] uppercase tracking-wider mb-3">Aktiva användare</h3>
          <div class="space-y-3">
            <% users.forEach(function(u) { %>
              <div class="flex items-center justify-between bg-[#f0f4f8] rounded-xl px-5 py-3">
                <div class="flex items-center gap-3">
                  <div class="w-9 h-9 rounded-full bg-[#0c56d0]/10 flex items-center justify-center text-[#0c56d0] font-bold text-xs"><%= u.name.substring(0,2).toUpperCase() %></div>
                  <div>
                    <p class="text-sm font-semibold"><%= u.name %></p>
                    <p class="text-xs text-[#566168]"><%= u.email %> &middot; <%= u.role %></p>
                  </div>
                </div>
                <div class="flex items-center gap-3">
                  <% if (u.role !== 'admin') { %>
                    <button onclick="navigator.clipboard.writeText(location.origin+'/invoices?token=<%= u.token %>'); this.textContent='Kopierad!'; setTimeout(() => this.textContent='Kopiera länk', 2000)" class="text-[#0c56d0] text-xs font-medium hover:underline">Kopiera länk</button>
                    <form method="POST" action="/settings/users/remove" class="inline">
                      <input type="hidden" name="email" value="<%= u.email %>"/>
                      <button type="submit" class="text-red-400 hover:text-red-600 transition-colors text-xs font-medium">Ta bort</button>
                    </form>
                  <% } else { %>
                    <span class="text-xs text-[#566168]">Admin</span>
                  <% } %>
                </div>
              </div>
            <% }); %>
          </div>
        </div>

        <form method="POST" action="/settings/users/invite" class="border-t border-[#e8eff4] pt-6">
          <h3 class="text-sm font-semibold text-[#566168] uppercase tracking-wider mb-3">Bjud in ny användare</h3>
          <div class="grid grid-cols-1 md:grid-cols-3 gap-3">
            <input type="text" name="name" placeholder="Namn" required class="bg-white border border-[#a8b3bb]/20 rounded-xl px-4 py-3 text-sm focus:ring-2 focus:ring-[#0c56d0]/20 focus:border-[#0c56d0] outline-none"/>
            <input type="email" name="email" placeholder="E-post" required class="bg-white border border-[#a8b3bb]/20 rounded-xl px-4 py-3 text-sm focus:ring-2 focus:ring-[#0c56d0]/20 focus:border-[#0c56d0] outline-none"/>
            <button type="submit" class="bg-gradient-to-br from-[#0c56d0] to-[#004aba] text-white font-manrope font-bold py-3 px-6 rounded-xl shadow-lg shadow-[#0c56d0]/20 hover:opacity-95 active:scale-[0.98] transition-all flex items-center justify-center gap-2 text-sm">
              <span class="material-symbols-outlined text-sm">person_add</span> Bjud in
            </button>
          </div>
        </form>
      </div>

      <!-- Supplier rules -->
      <div class="bg-white rounded-xl shadow-[0_8px_48px_rgba(41,52,58,0.06)] border border-[#a8b3bb]/10 p-8">
        <h2 class="text-lg font-bold font-manrope mb-2 flex items-center gap-2">
          <span class="material-symbols-outlined text-[#0c56d0]">local_shipping</span> Leverantörsregler
        </h2>
        <p class="text-[#566168] text-sm mb-6">Definiera vilka avsändare som ska matchas vid Gmail-polling.</p>

        <div class="space-y-3 mb-6">
          <% rules.forEach(function(r, idx) { %>
            <div class="flex items-center justify-between bg-[#f0f4f8] rounded-xl px-5 py-3">
              <div class="flex items-center gap-3">
                <span class="material-symbols-outlined text-[#0c56d0]">mail</span>
                <div>
                  <p class="text-sm font-semibold font-mono"><%= r.from %></p>
                  <p class="text-xs text-[#566168]">Matchar: "<%= r.subject_contains || r.subject_regex || '*' %>"</p>
                </div>
              </div>
              <form method="POST" action="/settings/rules/remove" class="inline">
                <input type="hidden" name="index" value="<%= idx %>"/>
                <button type="submit" class="text-red-400 hover:text-red-600 transition-colors text-xs font-medium">Ta bort</button>
              </form>
            </div>
          <% }); %>
        </div>

        <form method="POST" action="/settings/rules/add" class="border-t border-[#e8eff4] pt-6">
          <h3 class="text-sm font-semibold text-[#566168] uppercase tracking-wider mb-3">Lägg till leverantör</h3>
          <div class="grid grid-cols-1 md:grid-cols-3 gap-3">
            <input type="email" name="from" placeholder="avsändare@företag.se" required class="bg-white border border-[#a8b3bb]/20 rounded-xl px-4 py-3 text-sm focus:ring-2 focus:ring-[#0c56d0]/20 focus:border-[#0c56d0] outline-none"/>
            <input type="text" name="subject_contains" placeholder="Ämne innehåller (t.ex. Faktura)" class="bg-white border border-[#a8b3bb]/20 rounded-xl px-4 py-3 text-sm focus:ring-2 focus:ring-[#0c56d0]/20 focus:border-[#0c56d0] outline-none"/>
            <button type="submit" class="bg-gradient-to-br from-[#0c56d0] to-[#004aba] text-white font-manrope font-bold py-3 px-6 rounded-xl shadow-lg shadow-[#0c56d0]/20 hover:opacity-95 active:scale-[0.98] transition-all flex items-center justify-center gap-2 text-sm">
              <span class="material-symbols-outlined text-sm">add</span> Lägg till
            </button>
          </div>
        </form>
      </div>
    </div>
  </main>
</body>
</html>
